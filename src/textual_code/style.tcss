    align: center middle;
}

UnsavedChangeModalScreen #dialog {
    grid-size: 3 3;
    grid-gutter: 1 2;
    grid-rows: 1fr 1fr 3;
    padding: 0 1;
    max-width: 60;
    max-height: 9;
    border: thick $background 80%;
    background: $surface;
}

UnsavedChangeModalScreen #title {
    column-span: 3;
    height: 1fr;
    width: 1fr;
    content-align: center middle;
}

UnsavedChangeModalScreen #message {
    column-span: 3;
    height: 1fr;
    width: 1fr;
    content-align: center middle;
}

UnsavedChangeModalScreen Button {
