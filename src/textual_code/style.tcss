Sidebar {
    dock: left;
    width: 20;
}

SidebarResizeHandle {
    dock: right;
    width: 1;
    background: $surface;
}

SidebarResizeHandle:hover {
    background: $primary-darken-2;
}

FindReplaceBar {
    dock: top;
    display: none;
    height: auto;
    background: $surface;
    padding: 0 1;
    layout: vertical;
}

FindReplaceBar #find_row {
    height: 3;
    layout: horizontal;
}

FindReplaceBar #replace_row {
    height: 3;
    layout: horizontal;
    display: none;
}

FindReplaceBar #find_input {
    width: 1fr;
}

FindReplaceBar #replace_input {
    width: 1fr;
}

FindReplaceBar #next_match,
FindReplaceBar #replace_btn,
FindReplaceBar #replace_all_btn {
    width: auto;
    min-width: 10;
}

FindReplaceBar #close_btn {
    width: 5;
}

CodeEditorFooter {
    dock: bottom;
    height: 1;
    margin: 0 1;
    layout: grid;
    grid-size: 6 1;
    grid-gutter: 0 1;
    grid-columns: 1fr auto auto auto auto auto;
}

CodeEditorFooter #path {
    width: 100%;
    background: $surface;
}

CodeEditorFooter #cursor_btn {
    text-align: center;
    min-width: 20;
    height: 1;
    padding: 0 1;
    border: none;
}

CodeEditorFooter #line_ending_btn {
    text-align: center;
    min-width: 0;
    height: 1;
    padding: 0 1;
    border: none;
}

CodeEditorFooter #encoding_btn {
    text-align: center;
    min-width: 0;
    height: 1;
    padding: 0 1;
    border: none;
}

CodeEditorFooter #indent_btn {
    text-align: center;
    min-width: 0;
    height: 1;
    padding: 0 1;
    border: none;
}

CodeEditorFooter #language {
    text-align: center;
    min-width: 0;
    height: 1;
    padding: 0 1;
    border: none;
}

SaveAsModalScreen {
    align: center middle;
}

SaveAsModalScreen #dialog {
    grid-size: 2 3;
    grid-gutter: 1 2;
    grid-rows: 1fr 3 3;
    padding: 0 1;
    max-width: 60;
    max-height: 11;
    border: thick $background 80%;
    background: $surface;
}

SaveAsModalScreen #title {
    column-span: 2;
    height: 1fr;
    width: 1fr;
    content-align: center middle;
}

SaveAsModalScreen #path {
    column-span: 2;
    height: 1fr;
    width: 1fr;
    content-align: center middle;
}

SaveAsModalScreen Button {
    width: 100%;
}

