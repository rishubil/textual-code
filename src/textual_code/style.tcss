/* Workspace search panel */
WorkspaceSearchPane {
    height: 1fr;
    layout: vertical;
}

WorkspaceSearchPane #ws-search-bar {
    height: auto;
}

WorkspaceSearchPane #ws-query {
    width: 1fr;
}

WorkspaceSearchPane #ws-regex {
    width: auto;
    height: 3;
}

WorkspaceSearchPane #ws-search {
    width: auto;
    height: 3;
}

WorkspaceSearchPane #ws-replace-bar {
    height: auto;
}

WorkspaceSearchPane #ws-replace {
    width: 1fr;
}

WorkspaceSearchPane #ws-replace-all {
    width: auto;
    height: 3;
}

WorkspaceSearchPane #ws-replace-status {
    height: 1;
    color: $success;
}

WorkspaceSearchPane #ws-results {
    height: 1fr;
}

/* Draggable tab visual feedback */
.tab.-dragging {
    color: $accent;
}

/* Edge drop zone visual indicator */
DraggableTabbedContent.-edge-hover {
    border-right: outer $accent;
}

/* Split view layout */
SplitContainer {
    width: 1fr;
    height: 1fr;
}

SplitContainer.split-horizontal {
    layout: horizontal;
}

SplitContainer.split-vertical {
    layout: vertical;
}

DraggableTabbedContent {
    width: 1fr;
    height: 1fr;
}

SplitResizeHandle {
    width: 1;
    background: $surface;
    pointer: ew-resize;
}

SplitResizeHandle:hover {
    background: $primary-darken-2;
}

SplitContainer.split-vertical > SplitResizeHandle {
    width: 100%;
    height: 1;
    pointer: ns-resize;
}

SplitContainer.split-vertical > DraggableTabbedContent {
    height: 1fr;
    width: 100%;
}

#markdown_preview {
    width: 1fr;
    display: none;
    border-left: tall $primary-darken-2;
    overflow-y: auto;
}
